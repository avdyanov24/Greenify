# Greenify Server Environment Variables
DATABASE_URL=postgresql://user:password@localhost:5432/greenify

# JWT Secret (generate a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Stripe API Key
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=greenify-images
R2_PUBLIC_URL=https://your-domain.r2.dev

# Server
NODE_ENV=development
PORT=3000

# AI Image Detection (future enhancement)
# IMAGE_AI_SERVICE_URL=https://api.example.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
